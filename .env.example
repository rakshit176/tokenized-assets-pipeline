# ──────────────────────────────────────────────
# Tokenized Assets Pipeline — Environment Config
# ──────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: zai | openai | anthropic | openrouter
LLM_PROVIDER=openai

# ── Z.AI (free, default) ──────────────────────
ZAI_API_KEY=""
ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4-plus-0111

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenRouter ─────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── SearXNG ────────────────────────────────────
# Local: http://localhost:8888 | Docker: http://searxng:8080
SEARXNG_URL=http://localhost:8888
SEARXNG_SECRET=""

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Pipeline ───────────────────────────────────
PIPELINE_TIMEOUT=300
LLM_TIMEOUT=90
LOG_LEVEL=INFO
